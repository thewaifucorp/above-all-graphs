// --- AI chat -----------------------------------------------------------------
// Multi-provider chat grounded on this graph (SPEC section 8, task 3).
// The page is static and offline, so the browser calls the provider directly
// with the user's own key — Anthropic via /v1/messages (with the documented
// browser-access header), OpenAI via /v1/chat/completions, Ollama locally.
// The key never touches any server of ours; it lives in localStorage only.
function toggleChat(force) {
  const chat = document.getElementById("chat-panel");
  const open = force !== undefined ? force : !chat.classList.contains("open");
  chat.classList.toggle("open", open);
  document.getElementById("chat-btn").classList.toggle("active", open);
  if (open) {
    document.getElementById("panel").style.display = "none";
    document.getElementById("chat-text").focus();
  }
}
document.getElementById("chat-btn").addEventListener("click", () => toggleChat());

// Provider registry — same roster GitNexus exposes. `compat` marks an
// OpenAI-compatible /chat/completions endpoint; anthropic/gemini/azure have
// their own wire formats. Colors follow the samvrai spectrum.
const CHAT_PROVIDERS = {
  anthropic:      { label: "Anthropic",  color: "#ff8a3b", model: "claude-opus-4-8", needsKey: true },
  openai:         { label: "OpenAI",     color: "#3bff6e", model: "gpt-4o-mini", compat: "https://api.openai.com/v1", needsKey: true },
  "azure-openai": { label: "Azure",      color: "#3bd8ff", model: "gpt-4o-mini", needsKey: true, needsUrl: true, urlLabel: "Azure endpoint", urlPlaceholder: "https://<resource>.openai.azure.com" },
  gemini:         { label: "Gemini",     color: "#7a3bff", model: "gemini-2.0-flash", needsKey: true },
  openrouter:     { label: "OpenRouter", color: "#ff3b3b", model: "openrouter/auto", compat: "https://openrouter.ai/api/v1", needsKey: true },
  minimax:        { label: "MiniMax",    color: "#f06292", model: "MiniMax-M2", compat: "https://api.minimax.io/v1", needsKey: true },
  glm:            { label: "GLM",        color: "#ffcf3b", model: "glm-4.6", compat: "https://api.z.ai/api/paas/v4", needsKey: true },
  ollama:         { label: "Ollama",     color: "#f2f2ee", model: "llama3.1", needsUrl: true, urlLabel: "Ollama URL", urlPlaceholder: "http://localhost:11434", defaultUrl: "http://localhost:11434" },
};
let chatCfg = {
  provider: "anthropic",
  keys: {},
  urls: { ollama: "http://localhost:11434" },
  models: {},
  ...JSON.parse(localStorage.getItem("aag-chat-config") || "{}"),
};
// migrate the earlier single-key shape
if (chatCfg.key && !chatCfg.keys[chatCfg.provider]) chatCfg.keys[chatCfg.provider] = chatCfg.key;
if (chatCfg.url && !chatCfg.urls.ollama) chatCfg.urls.ollama = chatCfg.url;
chatCfg.keys = chatCfg.keys || {};
chatCfg.urls = chatCfg.urls || {};
for (const [p, def] of Object.entries(CHAT_PROVIDERS)) {
  if (!chatCfg.models[p]) chatCfg.models[p] = def.model;
}
if (!CHAT_PROVIDERS[chatCfg.provider]) chatCfg.provider = "anthropic";
function saveChatCfg() { localStorage.setItem("aag-chat-config", JSON.stringify(chatCfg)); }
const chatKey = () => chatCfg.keys[chatCfg.provider] || "";
const chatUrl = () => chatCfg.urls[chatCfg.provider] || CHAT_PROVIDERS[chatCfg.provider].defaultUrl || "";

// Stable graph digest: goes first in the system prompt so Anthropic's prompt
// cache (prefix match) can reuse it across questions.
const CHAT_SYSTEM = (() => {
  const files = nodes.filter((n) => n.kind === "file");
  const fileLines = files
    .map((f) => {
      const syms = nodes.filter((n) => n.file === f.file && n.kind !== "file" && n.kind !== "doc").length;
      return `- ${f.file} (${syms} symbols)`;
    })
    .join("\n");
  const hubs = nodes
    .slice()
    .sort((a, b) => b.degree - a.degree)
    .slice(0, 14)
    .map((n) => `- ${n.name} (${n.kind}, ${n.file}:${n.startLine}, ${n.degree} connections)`)
    .join("\n");
  const mods = communityMeta.map((m) => `- ${m.name} (${m.size} nodes)`).join("\n");
  return (
    `You are the assistant embedded in aag ("above all graphs"), an offline code-graph explorer. ` +
    `You are looking at the indexed repository "__REPO_NAME__" (${nodes.length} nodes, ${links.length} edges). ` +
    `Answer questions about this codebase using the graph data and source snippets provided. ` +
    `Cite locations as file:line. If the provided context is not enough, say what is missing instead of guessing.\n\n` +
    `Files:\n${fileLines}\n\nMost connected symbols:\n${hubs}\n\nModules (detected communities):\n${mods}`
  );
})();

// Per-question retrieval: match query words against node names/files, ship
// the best nodes with their edges and a source slice as context.
function chatRetrieve(question) {
  const words = [...new Set(question.toLowerCase().match(/[a-z_][a-z0-9_]{2,}/g) || [])];
  if (words.length === 0) return "";
  const scored = [];
  for (const n of nodes) {
    const name = n.name.toLowerCase();
    const file = n.file.toLowerCase();
    let score = 0;
    for (const w of words) {
      if (name === w) score += 6;
      else if (name.includes(w)) score += 3;
      if (file.includes(w)) score += 1;
    }
    if (score > 0) scored.push([score + Math.min(n.degree, 10) * 0.1, n]);
  }
  scored.sort((a, b) => b[0] - a[0]);
  const parts = [];
  let budget = 9000;
  for (const [, n] of scored.slice(0, 6)) {
    const callers = links.filter((l) => l.target === n.id).slice(0, 8).map((l) => `${l.s.name} (${l.s.file}:${l.s.startLine})`);
    const callees = links.filter((l) => l.source === n.id).slice(0, 8).map((l) => `${l.t.name} (${l.t.file}:${l.t.startLine})`);
    let block = `### ${n.kind} ${n.name} — ${n.file}:${n.startLine}-${n.endLine}\n`;
    if (callers.length) block += `Called by: ${callers.join(", ")}\n`;
    if (callees.length) block += `Calls: ${callees.join(", ")}\n`;
    const src = FILES[n.file];
    if (src && n.kind !== "file" && n.kind !== "doc") {
      const all = src.split("\n");
      const from = Math.max(0, n.startLine - 1);
      const to = Math.min(all.length, Math.min(n.endLine, n.startLine + 60));
      block += "```\n" + all.slice(from, to).join("\n") + "\n```\n";
    }
    if (budget - block.length < 0) break;
    budget -= block.length;
    parts.push(block);
  }
  return parts.length ? `\n\n<graph_context>\n${parts.join("\n")}</graph_context>` : "";
}

const chatHistory = []; // [{role, content}] — full contents incl. retrieval blocks
let chatAbort = null;

function chatMdLite(text) {
  // fences first, then inline code, on escaped text
  const esc = escapeHtml(text);
  let out = "";
  const segs = esc.split(/```[a-zA-Z]*\n?/);
  for (let i = 0; i < segs.length; i++) {
    if (i % 2 === 1) out += `<pre><code>${segs[i]}</code></pre>`;
    else out += segs[i].replace(/`([^`\n]+)`/g, "<code>$1</code>");
  }
  return out;
}

function chatAddMsg(cls, who) {
  const msgs = document.getElementById("chat-msgs");
  const empty = msgs.querySelector(".empty");
  if (empty) empty.remove();
  const div = document.createElement("div");
  div.className = `msg ${cls}`;
  div.innerHTML = `<div class="who">${who}</div><div class="body"></div>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  return div.querySelector(".body");
}

// Shared line reader over a streaming fetch body.
async function chatReadLines(resp, onLine) {
  const reader = resp.body.getReader();
  const dec = new TextDecoder();
  let buf = "";
  for (;;) {
    const { done, value } = await reader.read();
    if (done) break;
    buf += dec.decode(value, { stream: true });
    const lines = buf.split("\n");
    buf = lines.pop();
    for (const line of lines) onLine(line);
  }
  if (buf) onLine(buf);
}

// OpenAI-compatible SSE — serves OpenAI, OpenRouter, MiniMax, GLM and Azure
// (Azure differs only in URL shape and auth header).
async function openaiCompatStream(url, headers, model, onText, signal) {
  const resp = await fetch(url, {
    method: "POST",
    signal,
    headers: { "content-type": "application/json", ...headers },
    body: JSON.stringify({
      model,
      stream: true,
      messages: [{ role: "system", content: CHAT_SYSTEM }, ...chatHistory],
    }),
  });
  if (!resp.ok) throw new Error(await chatApiError(resp));
  await chatReadLines(resp, (line) => {
    if (!line.startsWith("data: ") || line.includes("[DONE]")) return;
    const data = JSON.parse(line.slice(6));
    const text = data.choices?.[0]?.delta?.content;
    if (text) onText(text);
  });
}

async function chatStream(onText, signal) {
  const p = chatCfg.provider;
  const def = CHAT_PROVIDERS[p];
  const model = chatCfg.models[p];
  const key = chatKey();
  if (p === "anthropic") {
    const resp = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      signal,
      headers: {
        "content-type": "application/json",
        "x-api-key": key,
        "anthropic-version": "2023-06-01",
        "anthropic-dangerous-direct-browser-access": "true",
      },
      body: JSON.stringify({
        model,
        max_tokens: 64000,
        stream: true,
        system: [{ type: "text", text: CHAT_SYSTEM, cache_control: { type: "ephemeral" } }],
        messages: chatHistory,
      }),
    });
    if (!resp.ok) throw new Error(await chatApiError(resp));
    await chatReadLines(resp, (line) => {
      if (!line.startsWith("data: ")) return;
      const data = JSON.parse(line.slice(6));
      if (data.type === "content_block_delta" && data.delta.type === "text_delta") onText(data.delta.text);
      if (data.type === "error") throw new Error(data.error.message);
    });
  } else if (p === "gemini") {
    const contents = chatHistory.map((m) => ({ role: m.role === "assistant" ? "model" : "user", parts: [{ text: m.content }] }));
    const resp = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/${encodeURIComponent(model)}:streamGenerateContent?alt=sse&key=${encodeURIComponent(key)}`,
      {
        method: "POST",
        signal,
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ systemInstruction: { parts: [{ text: CHAT_SYSTEM }] }, contents }),
      }
    );
    if (!resp.ok) throw new Error(await chatApiError(resp));
    await chatReadLines(resp, (line) => {
      if (!line.startsWith("data: ")) return;
      const data = JSON.parse(line.slice(6));
      const parts = data.candidates?.[0]?.content?.parts || [];
      for (const part of parts) if (part.text) onText(part.text);
    });
  } else if (p === "azure-openai") {
    const base = chatUrl().replace(/\/$/, "");
    if (!base) throw new Error("Set your Azure endpoint URL first (⚙).");
    await openaiCompatStream(
      `${base}/openai/deployments/${encodeURIComponent(model)}/chat/completions?api-version=2024-10-21`,
      { "api-key": key },
      model,
      onText,
      signal
    );
  } else if (def.compat) {
    await openaiCompatStream(`${def.compat}/chat/completions`, { authorization: `Bearer ${key}` }, model, onText, signal);
  } else {
    // ollama
    const base = chatUrl().replace(/\/$/, "");
    let resp;
    try {
      resp = await fetch(`${base}/api/chat`, {
        method: "POST",
        signal,
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          model,
          stream: true,
          messages: [{ role: "system", content: CHAT_SYSTEM }, ...chatHistory],
        }),
      });
    } catch (e) {
      throw new Error(`Could not reach Ollama at ${base}. Is it running? For pages opened from file://, start it with OLLAMA_ORIGINS="*".`);
    }
    if (!resp.ok) throw new Error(await chatApiError(resp));
    await chatReadLines(resp, (line) => {
      if (!line.trim()) return;
      const data = JSON.parse(line);
      if (data.message?.content) onText(data.message.content);
      if (data.error) throw new Error(data.error);
    });
  }
}

async function chatApiError(resp) {
  try {
    const j = await resp.json();
    return j.error?.message || j.error || `HTTP ${resp.status}`;
  } catch {
    return `HTTP ${resp.status}`;
  }
}

async function chatSend() {
  const ta = document.getElementById("chat-text");
  const btn = document.getElementById("chat-send");
  const question = ta.value.trim();
  if (!question || chatAbort) return;
  if (CHAT_PROVIDERS[chatCfg.provider].needsKey && !chatKey()) {
    toggleChatConfig(true);
    chatAddMsg("assistant err", "aag").textContent = "Set an API key first (⚙ in the chat header).";
    return;
  }
  ta.value = "";
  chatAddMsg("user", "you").textContent = question;
  chatHistory.push({ role: "user", content: question + chatRetrieve(question) });

  const body = chatAddMsg("assistant", chatCfg.provider);
  body.textContent = "…";
  btn.textContent = "■";
  btn.classList.add("stop");
  chatAbort = new AbortController();
  let full = "";
  const msgs = document.getElementById("chat-msgs");
  try {
    await chatStream((text) => {
      if (full === "") body.textContent = "";
      full += text;
      body.textContent = full;
      msgs.scrollTop = msgs.scrollHeight;
    }, chatAbort.signal);
    body.innerHTML = chatMdLite(full);
    chatHistory.push({ role: "assistant", content: full });
  } catch (e) {
    if (e.name === "AbortError") {
      if (full) chatHistory.push({ role: "assistant", content: full });
      body.innerHTML = chatMdLite(full) + `<div style="color:var(--text-dim)">— stopped —</div>`;
    } else {
      chatHistory.pop(); // failed turn: drop the user message so a retry is clean
      body.parentElement.classList.add("err");
      body.textContent = String(e.message || e);
    }
  } finally {
    chatAbort = null;
    btn.textContent = "→";
    btn.classList.remove("stop");
    msgs.scrollTop = msgs.scrollHeight;
  }
}

document.getElementById("chat-send").addEventListener("click", () => {
  if (chatAbort) chatAbort.abort();
  else chatSend();
});
document.getElementById("chat-text").addEventListener("keydown", (event) => {
  if (event.key === "Enter" && !event.shiftKey) {
    event.preventDefault();
    chatSend();
  }
});

// Provider config UI
function toggleChatConfig(force) {
  const box = document.getElementById("chat-config");
  const open = force !== undefined ? force : !box.classList.contains("open");
  box.classList.toggle("open", open);
  document.getElementById("chat-config-btn").classList.toggle("active", open);
}
document.getElementById("chat-config-btn").addEventListener("click", () => toggleChatConfig());

function buildProviderPills() {
  const box = document.getElementById("cc-providers");
  box.innerHTML = Object.entries(CHAT_PROVIDERS)
    .map(([id, def]) => `<button class="pv" data-p="${id}" style="--pv:${def.color}">${def.label}</button>`)
    .join("");
  for (const el of box.querySelectorAll(".pv")) {
    el.addEventListener("click", () => {
      chatCfg.provider = el.dataset.p;
      saveChatCfg();
      syncChatConfigUI();
    });
  }
}

function syncChatConfigUI() {
  const def = CHAT_PROVIDERS[chatCfg.provider];
  for (const el of document.querySelectorAll("#cc-providers .pv")) {
    el.classList.toggle("active", el.dataset.p === chatCfg.provider);
  }
  document.getElementById("cc-model").value = chatCfg.models[chatCfg.provider];
  document.getElementById("cc-key").value = chatKey();
  document.getElementById("cc-key-row").style.display = def.needsKey ? "block" : "none";
  document.getElementById("cc-url-row").style.display = def.needsUrl ? "block" : "none";
  if (def.needsUrl) {
    document.getElementById("cc-url-label").textContent = def.urlLabel;
    const urlInput = document.getElementById("cc-url");
    urlInput.placeholder = def.urlPlaceholder || "";
    urlInput.value = chatCfg.urls[chatCfg.provider] || def.defaultUrl || "";
  }
}
document.getElementById("cc-model").addEventListener("input", (event) => {
  chatCfg.models[chatCfg.provider] = event.target.value.trim();
  saveChatCfg();
});
document.getElementById("cc-key").addEventListener("input", (event) => {
  chatCfg.keys[chatCfg.provider] = event.target.value.trim();
  saveChatCfg();
});
document.getElementById("cc-url").addEventListener("input", (event) => {
  chatCfg.urls[chatCfg.provider] = event.target.value.trim();
  saveChatCfg();
});
buildProviderPills();
syncChatConfigUI();
if (CHAT_PROVIDERS[chatCfg.provider].needsKey && !chatKey()) toggleChatConfig(true);

// --- Settings ---------------------------------------------------------------
const sliders = {
  repulsion: { input: "s-repulsion", out: "v-repulsion", fmt: (v) => v },
  gravity: { input: "s-gravity", out: "v-gravity", fmt: (v) => v },
  cluster: { input: "s-cluster", out: "v-cluster", fmt: (v) => v },
  nodeScale: { input: "s-scale", out: "v-scale", fmt: (v) => `${v}x` },
  labelDensity: { input: "s-labels", out: "v-labels", fmt: (v) => v },
  edgeOpacity: { input: "s-edges", out: "v-edges", fmt: (v) => v },
};
function syncSlidersFromSettings() {
  for (const [key, { input, out, fmt }] of Object.entries(sliders)) {
    document.getElementById(input).value = settings[key];
    document.getElementById(out).textContent = fmt(settings[key]);
  }
  document.getElementById("s-livesim").checked = settings.liveSim;
}
for (const [key, { input, out, fmt }] of Object.entries(sliders)) {
  document.getElementById(input).addEventListener("input", (event) => {
    settings[key] = Number(event.target.value);
    document.getElementById(out).textContent = fmt(settings[key]);
    saveSettings();
    if (key === "nodeScale") syncSizes();
    if (key === "labelDensity" && renderer) renderer.setSetting("labelRenderedSizeThreshold", labelThreshold());
    refresh();
  });
}
document.getElementById("s-reset").addEventListener("click", () => {
  settings = { ...DEFAULT_SETTINGS };
  saveSettings();
  syncSlidersFromSettings();
  syncSizes();
  if (renderer) renderer.setSetting("labelRenderedSizeThreshold", labelThreshold());
  refresh();
});
document.getElementById("s-livesim").addEventListener("change", (event) => {
  settings.liveSim = event.target.checked;
  saveSettings();
  if (settings.liveSim) startSim(0.03);
});
document.getElementById("s-relayout").addEventListener("click", () => runLayout(true));
document.getElementById("fit-btn").addEventListener("click", () => fitView(500));
document.getElementById("settings-btn").addEventListener("click", () => {
  const panel = document.getElementById("settings-panel");
  const open = panel.style.display !== "block";
  panel.style.display = open ? "block" : "none";
  document.getElementById("settings-btn").classList.toggle("active", open);
});
syncSlidersFromSettings();

// --- Layout driver ----------------------------------------------------------
// Iterations scale down with graph size; work is chunked into batches so the
// progress bar paints and the tab never freezes, even at 5k+ nodes.
function runLayout(isRerun) {
  stopSim();
  const total = nodes.length > 5000 ? 160 : nodes.length > 1000 ? 260 : 400;
  const noverlapIters = 60;
  const progress = document.getElementById("progress");
  const fill = document.getElementById("progress-fill");
  if (!isRerun) progress.style.display = "flex";
  let iter = 0;

  function batch() {
    const chunk = nodes.length > 5000 ? 4 : 12;
    for (let i = 0; i < chunk && iter < total; i++, iter++) {
      fa2Step(Math.pow(1 - iter / total, 1.6));
    }
    fill.style.width = `${Math.round((iter / total) * 90)}%`;
    if (isRerun) { syncGraph(); refresh(); }
    if (iter < total) { setTimeout(batch, 0); return; }
    for (let i = 0; i < noverlapIters; i++) { if (noverlapStep() === 0) break; }
    fill.style.width = "100%";
    progress.style.display = "none";
    syncGraph();
    fitView(isRerun ? 500 : 0);
    refresh();
    if (!isRerun) applyFocusParam();
    // Small settle kick; decays to sleep unless liveSim keeps a floor.
    startSim(0.03);
  }
  setTimeout(batch, 0);
}

// Deep links: graph.html?focus=<file-or-symbol> (the wiki links back here).
function applyFocusParam() {
  const focus = new URLSearchParams(location.search).get("focus");
  if (!focus) return;
  const target =
    nodes.find((n) => n.file === focus && n.kind === "file") ||
    nodes.find((n) => n.name === focus) ||
    nodes.find((n) => n.file === focus);
  if (target) focusNode(target);
}

