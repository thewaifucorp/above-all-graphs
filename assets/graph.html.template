<script>/*__SIGMA_JS__*/</script>
<script>
const DATA = /*__GRAPH_DATA__*/;
const FILES = /*__FILES_DATA__*/;

// Module (community) colors — muted, readable on the dark surface without
// reading as neon. Assigned by module size; wraps past 16.
const PALETTE = [
  "#5e8ef7", "#4db894", "#c9a24c", "#c96a75", "#9a82d9", "#4fa8c9", "#c9825e", "#7fb85e",
  "#b8629e", "#54b8ad", "#a8944c", "#8a7ed9", "#c96a94", "#94b85e", "#c9944c", "#6aa2d9",
];
const EDGE_COLOR = "#33332f";
const EDGE_HL = "#ffc600";

const DEFAULT_SETTINGS = { repulsion: 8, gravity: 6, cluster: 8, nodeScale: 1, labelDensity: 4, edgeOpacity: 0.3, liveSim: false };
let settings = { ...DEFAULT_SETTINGS, ...JSON.parse(localStorage.getItem("aag-graph-settings") || "{}") };
function saveSettings() { localStorage.setItem("aag-graph-settings", JSON.stringify(settings)); }

// Deterministic PRNG (mulberry32, fixed seed) — the layout must come out the
// same every time the page opens, or the graph "moves" between visits.
function mulberry32(seed) {
  return () => {
    seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const nodes = DATA.nodes;
const byId = new Map(nodes.map((n) => [n.id, n]));
const links = DATA.edges.map((e) => ({ ...e, s: byId.get(e.source), t: byId.get(e.target) })).filter((e) => e.s && e.t);

const degree = new Map();
for (const e of links) {
  degree.set(e.source, (degree.get(e.source) || 0) + 1);
  degree.set(e.target, (degree.get(e.target) || 0) + 1);
}
for (const n of nodes) {
  n.degree = degree.get(n.id) || 0;
  n.mass = n.degree + 1;
}

// --- Community detection: deterministic label propagation ------------------
// Each node starts as its own community and repeatedly adopts the most
// common label among its neighbors (ties broken by smallest label, iteration
// in id order — fully deterministic). Tiny leftover communities are folded
// into the dominant community of their own file so stray helpers don't get
// their own color. Surfaced in the UI as "Modules".
function detectCommunities() {
  const adj = new Map(nodes.map((n) => [n.id, []]));
  for (const e of links) {
    adj.get(e.source).push(e.target);
    adj.get(e.target).push(e.source);
  }
  const label = new Map(nodes.map((n) => [n.id, n.id]));
  const order = nodes.map((n) => n.id).sort((a, b) => a - b);
  for (let round = 0; round < 30; round++) {
    let changed = false;
    for (const id of order) {
      const counts = new Map();
      for (const nb of adj.get(id)) {
        const l = label.get(nb);
        counts.set(l, (counts.get(l) || 0) + 1);
      }
      if (counts.size === 0) continue;
      let best = label.get(id);
      let bestCount = counts.get(best) || 0;
      for (const [l, c] of counts) {
        if (c > bestCount || (c === bestCount && l < best)) { best = l; bestCount = c; }
      }
      if (best !== label.get(id)) { label.set(id, best); changed = true; }
    }
    if (!changed) break;
  }

  const sizes = new Map();
  for (const n of nodes) sizes.set(label.get(n.id), (sizes.get(label.get(n.id)) || 0) + 1);

  const dominantByFile = new Map();
  for (const n of nodes) {
    const l = label.get(n.id);
    const cur = dominantByFile.get(n.file);
    if (!cur || sizes.get(l) > sizes.get(cur)) dominantByFile.set(n.file, l);
  }
  for (const n of nodes) {
    if (sizes.get(label.get(n.id)) < 3) {
      const dom = dominantByFile.get(n.file);
      if (dom !== undefined && sizes.get(dom) >= 3) label.set(n.id, dom);
    }
  }

  // Renumber by community size so index 0 = biggest = first palette color.
  const finalSizes = new Map();
  for (const n of nodes) finalSizes.set(label.get(n.id), (finalSizes.get(label.get(n.id)) || 0) + 1);
  const ranked = [...finalSizes.entries()].sort((a, b) => b[1] - a[1] || a[0] - b[0]).map(([l]) => l);
  const indexOf = new Map(ranked.map((l, i) => [l, i]));
  for (const n of nodes) n.community = indexOf.get(label.get(n.id));
  return ranked.length;
}

const communityCount = detectCommunities();
const communityColor = (c) => PALETTE[c % PALETTE.length];

// Human-readable module names: the most common directory among members
// plus the highest-degree symbol, e.g. "src/ · resolve_calls".
const communityMeta = [];
for (let c = 0; c < communityCount; c++) {
  const members = nodes.filter((n) => n.community === c);
  const dirCount = new Map();
  for (const m of members) {
    const dir = m.file.includes("/") ? m.file.slice(0, m.file.lastIndexOf("/") + 1) : "./";
    dirCount.set(dir, (dirCount.get(dir) || 0) + 1);
  }
  const topDir = [...dirCount.entries()].sort((a, b) => b[1] - a[1] || (a[0] < b[0] ? -1 : 1))[0][0];
  const top = members.slice().sort((a, b) => b.degree - a.degree || a.id - b.id)[0];
  communityMeta.push({ id: c, size: members.length, name: `${topDir} · ${top.name}` });
}

// --- Layout: ForceAtlas2 (Barnes-Hut via d3.quadtree) + noverlap -----------
// Per SPEC section 6: GitNexus and Graphify independently converged on
// ForceAtlas2 — generic D3 many-body doesn't settle into legible clusters at
// real-repo scale. Vendored implementation, no CDN. The initial layout runs
// to convergence behind the progress bar; drag reheats a short-lived
// simulation (see "Live simulation"). Perpetual motion is opt-in — it costs
// CPU, and the default must never freeze a weak machine.
const rand = mulberry32(42);
const radiusOf = (d) =>
  (d.kind === "file" || d.kind === "doc" ? 6 : 3.5) * settings.nodeScale +
  Math.min(Math.sqrt(d.degree) * 1.8, 14) * settings.nodeScale;

// Seed each community on a circle so clusters start — and stay — spatially
// separated instead of relying on the forces to untangle a random init.
const seeds = [];
{
  const R = 160 + 26 * Math.sqrt(nodes.length);
  for (let c = 0; c < communityCount; c++) {
    const angle = (2 * Math.PI * c) / communityCount;
    seeds.push({ x: Math.cos(angle) * R, y: Math.sin(angle) * R });
  }
  for (const n of nodes) {
    const s = seeds[n.community];
    const spread = 30 + 14 * Math.sqrt(communityMeta[n.community].size);
    const a = rand() * 2 * Math.PI;
    const r = Math.sqrt(rand()) * spread;
    n.x = s.x + Math.cos(a) * r;
    n.y = s.y + Math.sin(a) * r;
  }
}

function accumulateMass(quad) {
  if (quad.length) {
    let m = 0, x = 0, y = 0;
    for (let i = 0; i < 4; i++) {
      const q = quad[i];
      if (q && q.m) { m += q.m; x += q.x * q.m; y += q.y * q.m; }
    }
    quad.m = m; quad.x = x / m; quad.y = y / m;
  } else {
    let m = 0, q = quad;
    do { m += q.data.mass; } while ((q = q.next));
    quad.m = m; quad.x = quad.data.x; quad.y = quad.data.y;
  }
}

// `stepFloor` is the minimum per-tick displacement: 0.4 during the initial
// layout so convergence never stalls, 0 during the live simulation so idle
// motion stays subtle instead of jittering forever.
function fa2Step(alpha, stepFloor = 0.4) {
  const kr = settings.repulsion;
  const kg = settings.gravity * 0.12;
  const kc = settings.cluster * 0.1;
  for (const n of nodes) { n.dx = 0; n.dy = 0; }

  const tree = d3.quadtree(nodes, (d) => d.x, (d) => d.y);
  tree.visitAfter(accumulateMass);
  const theta2 = 1.2 * 1.2;

  for (const n of nodes) {
    tree.visit((quad, x0, y0, x1, y1) => {
      if (!quad.m) return true;
      const w = x1 - x0;
      let dx = n.x - quad.x, dy = n.y - quad.y;
      const dist2 = dx * dx + dy * dy;
      if ((w * w) / theta2 < dist2) {
        // Far region: treat as one body. FA2 repulsion F ∝ mass·mass / d.
        const f = (kr * n.mass * quad.m) / Math.max(dist2, 1);
        n.dx += dx * f; n.dy += dy * f;
        return true;
      }
      if (quad.length) return false;
      let q = quad;
      do {
        if (q.data !== n) {
          let ddx = n.x - q.data.x, ddy = n.y - q.data.y;
          let dd2 = ddx * ddx + ddy * ddy;
          if (dd2 < 0.01) { ddx = rand() - 0.5; ddy = rand() - 0.5; dd2 = ddx * ddx + ddy * ddy; }
          const f = (kr * n.mass * q.data.mass) / dd2;
          n.dx += ddx * f; n.dy += ddy * f;
        }
      } while ((q = q.next));
      return true;
    });
  }

  // Attraction: linear in distance, hub-dissuaded (divide by source mass) so
  // god nodes don't collapse their whole neighborhood onto themselves.
  for (const e of links) {
    const dx = e.t.x - e.s.x, dy = e.t.y - e.s.y;
    e.s.dx += dx / e.s.mass; e.s.dy += dy / e.s.mass;
    e.t.dx -= dx / e.t.mass; e.t.dy -= dy / e.t.mass;
  }

  for (const n of nodes) {
    // Gravity toward origin keeps disconnected components from drifting off.
    // Normal FA2 gravity (unit direction × mass, NOT scaled by distance) —
    // strong gravity crushes the community separation the seeds establish.
    const d = Math.hypot(n.x, n.y) || 1;
    const g = kg * n.mass;
    n.dx -= (n.x / d) * g;
    n.dy -= (n.y / d) * g;
    // Community pull toward its seed — this is what keeps the colored
    // clusters *organized* instead of interleaved.
    const s = seeds[n.community];
    n.dx += (s.x - n.x) * kc;
    n.dy += (s.y - n.y) * kc;

    const len = Math.hypot(n.dx, n.dy);
    if (len > 0) {
      const step = Math.min(len, 14 * alpha + stepFloor);
      n.x += (n.dx / len) * step;
      n.y += (n.dy / len) * step;
    }
  }
}

// Noverlap pass: after the layout settles, iteratively push overlapping
// nodes apart so every label anchor has breathing room (the dedicated pass
// both GitNexus and Graphify run after ForceAtlas2).
function noverlapStep() {
  const tree = d3.quadtree(nodes, (d) => d.x, (d) => d.y);
  let moved = 0;
  for (const n of nodes) {
    const r = radiusOf(n) + 2;
    tree.visit((quad, x0, y0, x1, y1) => {
      if (quad.length) return x0 > n.x + r + 30 || x1 < n.x - r - 30 || y0 > n.y + r + 30 || y1 < n.y - r - 30;
      let q = quad;
      do {
        const o = q.data;
        if (o !== n && o.id > n.id) {
          let dx = n.x - o.x, dy = n.y - o.y;
          let dist = Math.hypot(dx, dy);
          const min = r + radiusOf(o) + 2;
          if (dist < min) {
            if (dist < 0.01) { dx = rand() - 0.5; dy = rand() - 0.5; dist = Math.hypot(dx, dy); }
            const push = (min - dist) / dist / 2;
            n.x += dx * push; n.y += dy * push;
            o.x -= dx * push; o.y -= dy * push;
            moved++;
          }
        }
      } while ((q = q.next));
      return false;
    });
  }
  return moved;
}

// --- Sigma rendering ---------------------------------------------------------
// WebGL render layer (sigma.js v2 + graphology, both vendored — no CDN).
// Our own ForceAtlas2/noverlap physics keep computing positions on the plain
// node objects; sigma just draws them. This is what lets the same page handle
// multi-thousand-node repos where canvas 2D dropped frames.
const container = document.getElementById("view");
let selected = null;
let hoveredNode = null;
let isolatedCommunity = null;
let searchQuery = "";
const hiddenKinds = new Set();
const hiddenConf = new Set();
let renderer = null;
let camera = null;

// Sigma sizes are radii in px at zoom-neutral scale.
const sizeOf = (n) =>
  (n.kind === "file" || n.kind === "doc" ? 5 : 2.5) * settings.nodeScale +
  Math.min(Math.sqrt(n.degree) * 1.2, 9) * settings.nodeScale;

// WebGL edge colors carry no per-edge alpha, so the opacity slider maps to a
// gray ramp against the #0a0a0a background instead.
function edgeShade() {
  const v = Math.round(18 + settings.edgeOpacity * 110);
  return `rgb(${v},${v},${Math.max(0, v - 4)})`;
}

const graph = new graphology.Graph({ multi: true, type: "directed" });
for (const n of nodes) {
  graph.addNode(String(n.id), {
    x: n.x, y: n.y,
    size: sizeOf(n),
    color: communityColor(n.community),
    label: n.name,
    _n: n,
  });
}
{
  let ei = 0;
  for (const e of links) {
    graph.addEdgeWithKey(`e${ei++}`, String(e.source), String(e.target), { size: 1, _e: e });
  }
}

function nodeVisible(n) {
  if (hiddenKinds.has(n.kind)) return false;
  if (isolatedCommunity !== null && n.community !== isolatedCommunity) return false;
  if (searchQuery && !n.name.toLowerCase().includes(searchQuery) && !n.file.toLowerCase().includes(searchQuery)) return false;
  return true;
}

// Reducers: sigma consults these on every render — all our filter/hover/
// isolation state lives here instead of a hand-rolled draw loop.
function nodeReducer(key, data) {
  const n = data._n;
  const res = { ...data };
  if (hiddenKinds.has(n.kind)) { res.hidden = true; return res; }
  if (hoveredNode) {
    const nb = neighborsOf.get(hoveredNode.id);
    if (n !== hoveredNode && !(nb && nb.has(n.id))) { res.color = "#1a1a18"; res.label = null; }
  } else if ((isolatedCommunity !== null || searchQuery) && !nodeVisible(n)) {
    res.color = "#161614";
    res.label = null;
  }
  if (selected && n.id === selected.id) res.highlighted = true;
  return res;
}
function edgeReducer(key, data) {
  const e = data._e;
  const res = { ...data };
  if (hiddenConf.has(e.confidence)) { res.hidden = true; return res; }
  res.color = edgeShade();
  if (hoveredNode) {
    if (e.source === hoveredNode.id || e.target === hoveredNode.id) { res.color = EDGE_HL; res.size = 1.6; }
    else res.hidden = true;
  } else if ((isolatedCommunity !== null || searchQuery || hiddenKinds.size > 0) && !(nodeVisible(e.s) && nodeVisible(e.t))) {
    res.hidden = true;
  }
  return res;
}

function refresh() { if (renderer) renderer.refresh(); }
function syncGraph() {
  for (const n of nodes) graph.mergeNodeAttributes(String(n.id), { x: n.x, y: n.y });
}
function syncSizes() {
  for (const n of nodes) graph.setNodeAttribute(String(n.id), "size", sizeOf(n));
}

function labelThreshold() {
  // slider 1..10 (default 4): higher density → lower rendered-size cutoff.
  return Math.max(0.5, 13 - settings.labelDensity * 2);
}

function initRenderer() {
  renderer = new Sigma(graph, container, {
    minCameraRatio: 0.03,
    maxCameraRatio: 20,
    labelFont: '"JetBrains Mono", ui-monospace, monospace',
    labelSize: 10.5,
    labelWeight: "500",
    labelColor: { color: "#c9c9c3" },
    labelRenderedSizeThreshold: labelThreshold(),
    defaultEdgeColor: edgeShade(),
    nodeReducer,
    edgeReducer,
    allowInvalidContainer: true,
    // Sigma's default hover chip is a white rounded box — repaint it dark to
    // match the theme (also used for `highlighted` selected nodes).
    hoverRenderer: (context, data, hsettings) => {
      if (!data.label) return;
      const size = hsettings.labelSize;
      context.font = `${hsettings.labelWeight} ${size}px ${hsettings.labelFont}`;
      const w = context.measureText(data.label).width + 12;
      const x = data.x + data.size + 5;
      const y = data.y;
      context.fillStyle = "#121212";
      context.fillRect(x - 3, y - size / 2 - 5, w, size + 10);
      context.strokeStyle = "#373531";
      context.strokeRect(x - 3, y - size / 2 - 5, w, size + 10);
      context.fillStyle = "#f2f2ee";
      context.fillText(data.label, x + 3, y + size / 3);
    },
  });
  camera = renderer.getCamera();

  renderer.on("enterNode", ({ node }) => {
    hoveredNode = graph.getNodeAttribute(node, "_n");
    container.style.cursor = "pointer";
    refresh();
  });
  renderer.on("leaveNode", () => {
    hoveredNode = null;
    container.style.cursor = "default";
    refresh();
  });
  renderer.on("clickNode", ({ node }) => {
    selected = graph.getNodeAttribute(node, "_n");
    showPanel(selected);
    markTreeActive();
    refresh();
  });
  renderer.on("clickStage", () => {
    selected = null;
    document.getElementById("panel").style.display = "none";
    markTreeActive();
    refresh();
  });

  // Drag: the documented sigma v2 pattern — mouse captor owns the gesture,
  // preventSigmaDefault keeps the camera from panning underneath.
  renderer.on("downNode", (e) => {
    dragging = graph.getNodeAttribute(e.node, "_n");
    dragPos = [dragging.x, dragging.y];
    startSim(0.2);
  });
  renderer.getMouseCaptor().on("mousemovebody", (e) => {
    if (!dragging) return;
    const pos = renderer.viewportToGraph(e);
    dragPos = [pos.x, pos.y];
    dragging.x = pos.x;
    dragging.y = pos.y;
    graph.mergeNodeAttributes(String(dragging.id), { x: pos.x, y: pos.y });
    e.preventSigmaDefault();
    e.original.preventDefault();
    e.original.stopPropagation();
  });
  renderer.getMouseCaptor().on("mouseup", () => {
    dragging = null;
    dragPos = null;
  });
  renderer.getMouseCaptor().on("mousedown", () => {
    if (!renderer.getCustomBBox()) renderer.setCustomBBox(renderer.getBBox());
  });
}

function zoomToNode(n, ratio = 0.25) {
  const p = renderer && renderer.getNodeDisplayData(String(n.id));
  if (p) camera.animate({ x: p.x, y: p.y, ratio }, { duration: 600 });
}

function fitView(duration = 500) {
  if (!renderer) return;
  // 2nd/98th percentile bbox: stray disconnected nodes shouldn't shrink the
  // fit for everything actually connected.
  const xs = nodes.map((d) => d.x).sort((a, b) => a - b);
  const ys = nodes.map((d) => d.y).sort((a, b) => a - b);
  const at = (arr, p) => arr[Math.floor((arr.length - 1) * p)];
  renderer.setCustomBBox({ x: [at(xs, 0.02), at(xs, 0.98)], y: [at(ys, 0.02), at(ys, 0.98)] });
  if (duration === 0) camera.setState({ x: 0.5, y: 0.5, ratio: 1, angle: 0 });
  else camera.animate({ x: 0.5, y: 0.5, ratio: 1, angle: 0 }, { duration });
}

// --- Interaction ------------------------------------------------------------
const neighborsOf = new Map();
for (const e of links) {
  (neighborsOf.get(e.source) || neighborsOf.set(e.source, new Set()).get(e.source)).add(e.target);
  (neighborsOf.get(e.target) || neighborsOf.set(e.target, new Set()).get(e.target)).add(e.source);
}

// --- Live simulation ---------------------------------------------------------
// Drag (or the "Live simulation" toggle) reheats fa2Step at a small decaying
// alpha. Default OFF: the perpetual ticker costs real CPU and the graph must
// stay smooth on weak machines — motion is opt-in, drag always works.
let simAlpha = 0;
let simSleeping = true;
let simQueued = false;
let simTickCount = 0;
let dragging = null;
let dragPos = null;

function simFloor() {
  return settings.liveSim && nodes.length <= 2000 ? 0.012 : 0;
}

function startSim(alpha) {
  simAlpha = Math.max(simAlpha, alpha);
  if (simSleeping) { simSleeping = false; scheduleSim(); }
}

function scheduleSim() {
  if (simQueued) return;
  simQueued = true;
  const run = () => { if (!simQueued) return; simQueued = false; simTick(); };
  requestAnimationFrame(run);
  setTimeout(run, 120);
}

function simTick() {
  if (simSleeping) return;
  fa2Step(simAlpha, 0);
  if (dragging && simTickCount % 3 === 0 && nodes.length <= 2000) noverlapStep();
  if (dragging && dragPos) { dragging.x = dragPos[0]; dragging.y = dragPos[1]; }
  simAlpha = Math.max(simAlpha * 0.95, simFloor());
  simTickCount++;
  syncGraph();
  refresh();
  if (simAlpha <= 0.004 && !dragging) {
    simSleeping = true;
    return;
  }
  scheduleSim();
}

function stopSim() {
  simSleeping = true;
  simQueued = false;
  simAlpha = 0;
}

// --- Panels -----------------------------------------------------------------
function escapeHtml(s) {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}
function wikiSlug(path) {
  return path.replace(/[/\\.]/g, "_");
}

function showPanel(d) {
  const panel = document.getElementById("panel");
  panel.style.display = "block";
  const callers = links.filter((l) => l.target === d.id);
  const callees = links.filter((l) => l.source === d.id);
  const list = (edges, key) =>
    edges
      .map((e) => e[key])
      .filter(Boolean)
      .map((n) => `<li><code data-node="${n.id}">${escapeHtml(n.name)}</code> — ${escapeHtml(n.file)}:${n.startLine}</li>`)
      .join("");
  const hasSource = Object.hasOwn(FILES, d.file);
  const meta = communityMeta[d.community];
  panel.innerHTML = `
    <h2>${escapeHtml(d.kind)} <code>${escapeHtml(d.name)}</code></h2>
    <p>${escapeHtml(d.file)}:${d.startLine}-${d.endLine} &middot; ${d.degree} connection(s)</p>
    <p class="comm-chip"><span class="dot" style="background:${communityColor(d.community)}"></span>${escapeHtml(meta.name)} (${meta.size})</p>
    <div class="actions">
      ${hasSource ? `<button id="view-file-btn">View full file</button>` : ""}
      <a class="btn" href="wiki/${wikiSlug(d.file)}.html">Wiki page</a>
    </div>
    <h3>Called by / imported by</h3><ul>${list(callers, "s") || "<li>none</li>"}</ul>
    <h3>Calls / imports</h3><ul>${list(callees, "t") || "<li>none</li>"}</ul>
  `;
  if (hasSource) {
    document.getElementById("view-file-btn").addEventListener("click", () => openFile(d.file, d.startLine, d.endLine));
  }
  for (const el of panel.querySelectorAll("code[data-node]")) {
    el.addEventListener("click", () => {
      const n = byId.get(Number(el.dataset.node));
      if (n) { selected = n; showPanel(n); zoomToNode(n); markTreeActive(); refresh(); }
    });
  }
}

// --- Syntax highlighting (file modal) -----------------------------------------
// Tiny line-based tokenizer, not a real parser: comments, strings, numbers,
// keywords, Capitalized types. Good enough to make source readable; anything
// unrecognized falls through unstyled.
const LANG_KEYWORDS = {
  rust: "as async await break const continue crate dyn else enum extern false fn for if impl in let loop match mod move mut pub ref return self Self static struct super trait true type unsafe use where while",
  js: "async await break case catch class const continue debugger default delete do else export extends finally for from function if import in instanceof let new null of return static super switch this throw try typeof undefined var void while yield true false",
  py: "and as assert async await break class continue def del elif else except finally for from global if import in is lambda nonlocal not or pass raise return try while with yield None True False self",
  go: "break case chan const continue default defer else fallthrough for func go goto if import interface map package range return select struct switch type var nil true false",
  sh: "if then else elif fi for while until do done case esac function local export return exit echo",
  conf: "",
};
const EXT_LANG = { rs: "rust", js: "js", jsx: "js", ts: "js", tsx: "js", mjs: "js", cjs: "js", py: "py", go: "go", sh: "sh", bash: "sh", zsh: "sh", toml: "conf", yml: "conf", yaml: "conf", json: "conf", ini: "conf" };
const LINE_COMMENT = { rust: "//", js: "//", go: "//", py: "#", sh: "#", conf: "#" };
const BLOCK_COMMENT = { rust: true, js: true, go: true };
const KEYWORD_SETS = Object.fromEntries(Object.entries(LANG_KEYWORDS).map(([l, w]) => [l, new Set(w.split(" ").filter(Boolean))]));
const TOKEN_RES = {};
function tokenRegex(lang) {
  if (TOKEN_RES[lang]) return TOKEN_RES[lang];
  const parts = [];
  if (BLOCK_COMMENT[lang]) parts.push("\\/\\*[\\s\\S]*?\\*\\/", "\\/\\*.*$");
  const lc = LINE_COMMENT[lang];
  if (lc === "//") parts.push("\\/\\/.*$");
  else if (lc === "#") parts.push("#.*$");
  parts.push('"(?:[^"\\\\]|\\\\.)*"?', "'(?:[^'\\\\]|\\\\.)*'?", "`[^`]*`?");
  parts.push("\\b0[xX][0-9a-fA-F_]+\\b", "\\b\\d[\\d_]*(?:\\.\\d+)?\\b");
  parts.push("\\b[A-Za-z_]\\w*\\b");
  TOKEN_RES[lang] = new RegExp(parts.join("|"), "g");
  return TOKEN_RES[lang];
}
function langOf(file) {
  const ext = file.slice(file.lastIndexOf(".") + 1).toLowerCase();
  return EXT_LANG[ext] || null;
}
// `st.block` carries an open /* ... */ across lines.
function highlightLine(raw, lang, st) {
  if (!lang) return escapeHtml(raw);
  let out = "";
  let rest = raw;
  if (st.block) {
    const end = rest.indexOf("*/");
    if (end === -1) return `<span class="tk-c">${escapeHtml(rest)}</span>`;
    out += `<span class="tk-c">${escapeHtml(rest.slice(0, end + 2))}</span>`;
    st.block = false;
    rest = rest.slice(end + 2);
  }
  const kw = KEYWORD_SETS[lang];
  const re = tokenRegex(lang);
  re.lastIndex = 0;
  let last = 0;
  let m;
  while ((m = re.exec(rest)) !== null) {
    out += escapeHtml(rest.slice(last, m.index));
    const tok = m[0];
    let cls = null;
    const c0 = tok[0];
    if (tok.startsWith("//") || (c0 === "#" && LINE_COMMENT[lang] === "#")) cls = "tk-c";
    else if (tok.startsWith("/*")) {
      cls = "tk-c";
      if (!tok.endsWith("*/")) st.block = true;
    } else if (c0 === '"' || c0 === "'" || c0 === "`") cls = "tk-s";
    else if (c0 >= "0" && c0 <= "9") cls = "tk-n";
    else if (kw.has(tok)) cls = "tk-k";
    else if (c0 >= "A" && c0 <= "Z") cls = "tk-t";
    out += cls ? `<span class="${cls}">${escapeHtml(tok)}</span>` : escapeHtml(tok);
    last = m.index + tok.length;
  }
  out += escapeHtml(rest.slice(last));
  return out;
}

function openFile(file, startLine, endLine) {
  const content = FILES[file];
  if (content === undefined) return;
  document.getElementById("fm-title").textContent = file;
  const lang = langOf(file);
  const st = { block: false };
  const lines = content.split("\n");
  const body = lines
    .map((line, i) => {
      const n = i + 1;
      const hl = n >= startLine && n <= endLine ? " hl" : "";
      return `<div class="fm-line${hl}" data-line="${n}"><span class="fm-no">${n}</span><span class="fm-code">${highlightLine(line, lang, st)}</span></div>`;
    })
    .join("");
  const modal = document.getElementById("filemodal");
  const fmBody = document.getElementById("fm-body");
  fmBody.innerHTML = body;
  modal.style.display = "flex";
  const target = fmBody.querySelector(`[data-line="${startLine}"]`);
  if (target) target.scrollIntoView({ block: "center" });
}

document.getElementById("fm-close").addEventListener("click", () => {
