// --- Sidebar: explorer tree ---------------------------------------------------
function focusNode(n) {
  selected = n;
  showPanel(n);
  zoomToNode(n);
  markTreeActive();
  refresh();
}

function buildTree() {
  // One entry per file/doc node; nested by directory.
  const root = { dirs: new Map(), files: [] };
  const entries = nodes.filter((n) => n.kind === "file" || n.kind === "doc");
  entries.sort((a, b) => (a.file < b.file ? -1 : 1));
  for (const n of entries) {
    const parts = n.file.split("/");
    let cur = root;
    for (let i = 0; i < parts.length - 1; i++) {
      if (!cur.dirs.has(parts[i])) cur.dirs.set(parts[i], { dirs: new Map(), files: [] });
      cur = cur.dirs.get(parts[i]);
    }
    cur.files.push({ name: parts[parts.length - 1], node: n });
  }
  const render = (dir, depth) => {
    let html = "";
    for (const [name, sub] of [...dir.dirs.entries()].sort()) {
      html += `<details${depth < 2 ? " open" : ""}><summary>${escapeHtml(name)}/</summary>${render(sub, depth + 1)}</details>`;
    }
    for (const f of dir.files) {
      const ic = f.node.kind === "doc" ? "&#9671;" : "&#9642;";
      html += `<span class="leaf" data-node="${f.node.id}"><span class="ic">${ic}</span>${escapeHtml(f.name)}</span>`;
    }
    return html;
  };
  const tree = document.getElementById("tree");
  tree.innerHTML = render(root, 0);
  for (const el of tree.querySelectorAll(".leaf")) {
    el.addEventListener("click", () => {
      const n = byId.get(Number(el.dataset.node));
      if (n) focusNode(n);
    });
  }
}

function markTreeActive() {
  for (const el of document.querySelectorAll("#tree .leaf")) {
    el.classList.toggle("active", selected !== null && Number(el.dataset.node) === selected.id);
  }
}

// --- Sidebar: filters ----------------------------------------------------------
function setIsolated(c) {
  isolatedCommunity = c;
  for (const el of document.querySelectorAll("#f-modules .mod")) {
    el.classList.toggle("active", Number(el.dataset.c) === c);
  }
  refresh();
}

function buildFilters() {
  // Node kinds present in this graph, files first.
  const kindCounts = new Map();
  for (const n of nodes) kindCounts.set(n.kind, (kindCounts.get(n.kind) || 0) + 1);
  const kindOrder = ["file", "doc", ...[...kindCounts.keys()].filter((k) => k !== "file" && k !== "doc").sort()];
  const fk = document.getElementById("f-kinds");
  fk.insertAdjacentHTML(
    "beforeend",
    kindOrder
      .filter((k) => kindCounts.has(k))
      .map((k) => `<label class="frow"><input type="checkbox" checked data-kind="${k}">${k}<span class="n">${kindCounts.get(k)}</span></label>`)
      .join("")
  );
  for (const box of fk.querySelectorAll("input")) {
    box.addEventListener("change", () => {
      box.checked ? hiddenKinds.delete(box.dataset.kind) : hiddenKinds.add(box.dataset.kind);
      refresh();
    });
  }

  const confCounts = new Map();
  for (const e of links) confCounts.set(e.confidence, (confCounts.get(e.confidence) || 0) + 1);
  const fc = document.getElementById("f-conf");
  fc.insertAdjacentHTML(
    "beforeend",
    ["EXTRACTED", "INFERRED", "AMBIGUOUS"]
      .filter((c) => confCounts.has(c))
      .map((c) => `<label class="frow"><input type="checkbox" checked data-conf="${c}">${c.toLowerCase()}<span class="n">${confCounts.get(c)}</span></label>`)
      .join("")
  );
  for (const box of fc.querySelectorAll("input")) {
    box.addEventListener("change", () => {
      box.checked ? hiddenConf.delete(box.dataset.conf) : hiddenConf.add(box.dataset.conf);
      refresh();
    });
  }

  const fm = document.getElementById("f-modules");
  fm.insertAdjacentHTML(
    "beforeend",
    communityMeta
      .map(
        (m) =>
          `<div class="mod" data-c="${m.id}"><span class="dot" style="background:${communityColor(m.id)}"></span><span class="name">${escapeHtml(m.name)}</span><span class="n">${m.size}</span></div>`
      )
      .join("")
  );
  for (const el of fm.querySelectorAll(".mod")) {
    el.addEventListener("click", () => {
      const c = Number(el.dataset.c);
      setIsolated(isolatedCommunity === c ? null : c);
    });
  }
}

