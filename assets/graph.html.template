<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>aag — graph</title>
<style>
  /* Visual identity shared with samvrai-home: neutral near-black surfaces,
     warm off-white text, JetBrains Mono, red/yellow accents, and the
     "spectrum" rainbow line as the brand signature. */
  :root {
    --bg-0:           #0a0a0a;
    --bg-1:           #121212;
    --bg-2:           #1c1c1c;
    --border:         #262624;
    --border-bright:  #373531;
    --text-primary:   #f2f2ee;
    --text-secondary: #8a8a84;
    --text-dim:       #63635e;
    --accent:         #ffc600;
    --accent-dim:     rgba(255, 198, 0, 0.10);
    --red:            #c1121f;
    --red-bright:     #da3610;
    --mono:           "JetBrains Mono", ui-monospace, "SF Mono", "Cascadia Code", Menlo, Consolas, monospace;
    --spectrum:       linear-gradient(90deg, #ff3b3b, #ffcf3b, #3bff6e, #3bd8ff, #7a3bff);
  }
  html, body { margin: 0; height: 100%; background: var(--bg-0); color: var(--text-primary); font-family: var(--mono); overflow: hidden; }

  /* ---- header ---- */
  #header { position: fixed; top: 0; left: 0; right: 0; height: 46px; box-sizing: border-box; background: var(--bg-1); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; padding: 0 12px; z-index: 20; font-size: 12px; color: var(--text-secondary); }
  #header::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--spectrum); }
  #brand { display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--text-primary); }
  #brand .word { font-weight: 700; font-size: 14px; letter-spacing: 0.02em; }
  #brand .sub { color: var(--text-dim); font-size: 9px; margin-top: 1px; display: block; line-height: 1; white-space: nowrap; }
  #repo-pill { background: var(--bg-2); border: 1px solid var(--border); border-radius: 999px; padding: 4px 12px; color: var(--text-secondary); white-space: nowrap; }
  #repo-pill b { color: var(--text-primary); font-weight: 600; }
  /* Anchored to the true screen center (not flex-centered): siblings come
     and go — brand hides when embedded — and the search bar must not
     drift with them. */
  #search-wrap { position: absolute; left: 50%; transform: translateX(-50%); width: min(420px, 36vw); }
  #search { background: var(--bg-0); border: 1px solid var(--border); color: var(--text-primary); padding: 6px 14px; border-radius: 8px; width: 100%; font-size: 13px; outline: none; box-sizing: border-box; }
  #search:focus { border-color: var(--accent); }
  #search::placeholder { color: var(--text-dim); }
  #header .counts { white-space: nowrap; font-variant-numeric: tabular-nums; }
  #header .counts b { color: var(--text-primary); font-weight: 600; }
  #header button, #header a.hbtn { background: none; border: 1px solid var(--border); color: var(--text-secondary); border-radius: 8px; height: 28px; cursor: pointer; font-size: 12px; padding: 0 10px; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; transition: color 0.12s, border-color 0.12s; }
  #header button:hover, #header a.hbtn:hover { color: var(--text-primary); border-color: var(--border-bright); }
  #star-btn { color: var(--accent) !important; }
  #star-btn:hover { border-color: var(--accent) !important; }
  /* Inside the `aag ui` shell (an iframe): the shell's top bar already
     carries the lib-level chrome (brand, star/waifucorp) — hide those
     duplicates. Workspace-level navigation (wiki/report links) stays:
     that's this page's job, not the shell's — and when embedded it's the
     ONLY navigation, so it overrides the narrow-window media query that
     would otherwise hide it. */
  html.embedded #brand, html.embedded #star-btn, html.embedded #waifu-btn,
  html.embedded #repo-pill { display: none; }
  html.embedded #header a.hbtn[href="wiki/index.html"],
  html.embedded #header a.hbtn[href="report.html"] { display: inline-flex !important; }
  #waifu-btn { color: var(--red-bright) !important; }
  #waifu-btn:hover { border-color: var(--red-bright) !important; }
  #chat-btn.active, #settings-btn.active { color: var(--accent); border-color: var(--accent); }
  /* narrow windows: shed duplicated stats (statusbar repeats them) before the
     right-side action buttons overflow */
  @media (max-width: 1500px) { #header .counts { display: none; } }
  @media (max-width: 1300px) { #repo-pill { display: none; } #brand .sub { display: none; } }
  @media (max-width: 1100px) { #header a.hbtn[href="wiki/index.html"], #header a.hbtn[href="report.html"] { display: none; } }

  /* ---- sidebar ---- */
  /* Counts stay left, action/navigation buttons cluster right — the
     search bar owns the true center (absolutely positioned above). */
  #sidebar-btn { margin-left: auto; }
  /* Thin themed scrollbar — the platform default is a bright grey slab
     that fights the dark sidebar. */
  * { scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--border-bright); }
  #sidebar { position: fixed; top: 46px; left: 0; bottom: 24px; width: 250px; box-sizing: border-box; background: var(--bg-1); border-right: 1px solid var(--border); display: flex; flex-direction: column; z-index: 15; font-size: 12px; }
  body.sidebar-closed #sidebar { display: none; }
  #sidebar .tabs { display: flex; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  #sidebar .tabs button { flex: 1; background: none; border: none; color: var(--text-secondary); padding: 9px 0; cursor: pointer; font-size: 12px; border-bottom: 2px solid transparent; }
  #sidebar .tabs button.active { color: var(--text-primary); border-bottom-color: var(--accent); }
  #sidebar .tab-body { flex: 1; overflow-y: auto; padding: 8px; }
  #tab-filters { display: none; }
  /* explorer tree */
  #tree details { margin-left: 0; }
  #tree details details { margin-left: 12px; }
  #tree summary { list-style: none; cursor: pointer; padding: 3px 6px; border-radius: 6px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; user-select: none; }
  #tree summary::before { content: "\25B8"; display: inline-block; width: 12px; color: var(--text-dim); transition: transform 0.1s; }
  #tree details[open] > summary::before { transform: rotate(90deg); }
  #tree summary:hover { background: var(--bg-2); color: var(--text-primary); }
  #tree .leaf { display: block; padding: 3px 6px 3px 18px; border-radius: 6px; color: var(--text-secondary); cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  #tree .leaf:hover { background: var(--bg-2); color: var(--text-primary); }
  #tree .leaf.active { background: var(--accent-dim); color: var(--text-primary); }
  #tree .leaf .ic { color: var(--text-dim); margin-right: 5px; }
  /* filters */
  .fgroup { margin-bottom: 14px; }
  .fgroup h4 { margin: 6px 6px 6px; font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; }
  .fgroup label.frow { display: flex; align-items: center; gap: 7px; padding: 4px 6px; border-radius: 6px; color: var(--text-secondary); cursor: pointer; }
  .fgroup label.frow:hover { background: var(--bg-2); color: var(--text-primary); }
  .fgroup input[type="checkbox"] { accent-color: var(--accent); margin: 0; }
  .fgroup .frow .n { margin-left: auto; color: var(--text-dim); font-variant-numeric: tabular-nums; }
  .fgroup .mod { display: flex; align-items: center; gap: 7px; padding: 4px 6px; border-radius: 6px; color: var(--text-secondary); cursor: pointer; }
  .fgroup .mod:hover { background: var(--bg-2); color: var(--text-primary); }
  .fgroup .mod.active { background: var(--accent-dim); color: var(--text-primary); }
  .fgroup .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .fgroup .mod .name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .fgroup .mod .n { margin-left: auto; color: var(--text-dim); font-variant-numeric: tabular-nums; }

  /* ---- status bar ---- */
  #statusbar { position: fixed; left: 0; right: 0; bottom: 0; height: 24px; box-sizing: border-box; background: var(--bg-1); border-top: 1px solid var(--border); display: flex; align-items: center; gap: 16px; padding: 0 12px; z-index: 20; font-size: 11px; color: var(--text-dim); }
  #statusbar .ready { color: #3bff6e; }
  #statusbar .right { margin-left: auto; font-variant-numeric: tabular-nums; }

  /* ---- graph container (sigma renders its own canvases inside) ---- */
  #view { position: fixed; top: 46px; bottom: 24px; left: 250px; right: 0; }
  body.sidebar-closed #view { left: 0; }

  /* ---- progress ---- */
  #progress { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 30; background: var(--bg-0); flex-direction: column; gap: 14px; color: var(--text-secondary); font-size: 13px; letter-spacing: 0.03em; }
  #progress .bar { width: 240px; height: 3px; background: var(--bg-2); border-radius: 2px; overflow: hidden; }
  #progress .bar i { display: block; height: 100%; width: 0; background: var(--spectrum); border-radius: 2px; transition: width 0.1s; }

  /* ---- floating panels (right) ---- */
  .fpanel { position: fixed; top: 56px; right: 10px; bottom: 34px; width: 330px; box-sizing: border-box; background: var(--bg-1); border: 1px solid var(--border); border-radius: 12px; padding: 16px; overflow-y: auto; font-size: 13px; display: none; z-index: 16; box-shadow: 0 8px 28px rgba(0,0,0,0.45); }
  #settings-panel { bottom: auto; }
  #panel h2 { font-size: 14px; margin: 0 0 8px; color: var(--text-primary); }
  #panel h3 { font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin: 16px 0 6px; }
  #panel p { color: var(--text-secondary); margin: 4px 0; }
  #panel code { color: var(--accent); }
  #panel ul { padding-left: 16px; margin: 4px 0 8px; }
  #panel li { margin-bottom: 2px; color: var(--text-secondary); }
  #panel li code { cursor: pointer; }
  #panel .actions { display: flex; gap: 8px; margin-top: 10px; }
  #panel button, #panel a.btn { background: var(--bg-2); border: 1px solid var(--border); color: var(--text-primary); padding: 6px 12px; border-radius: 8px; cursor: pointer; font-size: 12px; text-decoration: none; display: inline-block; }
  #panel button:hover, #panel a.btn:hover { border-color: var(--accent); }
  #panel .comm-chip { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-secondary); }
  #panel .comm-chip .dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }
  #settings-panel h3 { margin: 0 0 12px; font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; }
  #settings-panel label { display: block; margin-bottom: 12px; color: var(--text-secondary); font-size: 12px; }
  #settings-panel label span { display: flex; justify-content: space-between; margin-bottom: 4px; }
  #settings-panel label.check { display: flex; align-items: center; gap: 8px; cursor: pointer; }
  #settings-panel input[type="range"] { width: 100%; accent-color: var(--accent); }
  #settings-panel input[type="checkbox"] { accent-color: var(--accent); }
  #settings-panel button { width: 100%; background: var(--bg-2); border: 1px solid var(--border); color: var(--text-primary); padding: 7px; border-radius: 8px; cursor: pointer; margin-top: 4px; }
  #settings-panel button:hover { border-color: var(--accent); }
  /* chat */
  #chat-panel { display: none; flex-direction: column; width: 380px; padding: 0; overflow: hidden; }
  #chat-panel.open { display: flex; }
  #chat-panel .chat-head { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px 10px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  #chat-panel .chat-head h3 { margin: 0; font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; }
  #chat-panel .chat-head button { background: none; border: 1px solid var(--border); border-radius: 6px; color: var(--text-secondary); height: 24px; width: 24px; cursor: pointer; font-size: 12px; }
  #chat-panel .chat-head button:hover, #chat-panel .chat-head button.active { color: var(--accent); border-color: var(--accent); }
  #chat-config { display: none; padding: 12px 14px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  #chat-config.open { display: block; }
  #chat-config label { display: block; margin-bottom: 10px; color: var(--text-secondary); font-size: 11px; }
  #chat-config input { display: block; width: 100%; box-sizing: border-box; margin-top: 4px; background: var(--bg-0); border: 1px solid var(--border); border-radius: 6px; color: var(--text-primary); padding: 6px 8px; font-size: 12px; font-family: var(--mono); }
  #chat-config input:focus { outline: none; border-color: var(--accent); }
  /* Provider picker: colored pill navbar (samvrai-home menu style) — each
     provider owns a spectrum hue; active pill fills with it. */
  #cc-providers { display: flex; gap: 5px; flex-wrap: wrap; margin: 6px 0 12px; }
  #cc-providers .pv { background: none; border: 1px solid var(--border); border-radius: 999px; padding: 4px 10px; font-size: 10.5px; color: var(--text-secondary); cursor: pointer; font-family: var(--mono); transition: all 0.12s; }
  #cc-providers .pv:hover { color: var(--pv, var(--text-primary)); border-color: var(--pv, var(--border-bright)); }
  #cc-providers .pv.active { background: var(--pv); border-color: var(--pv); color: #0b0f0d; font-weight: 700; }
  #chat-config .cc-note { margin: 0; font-size: 10.5px; color: var(--text-dim); line-height: 1.5; }
  #chat-msgs { flex: 1; overflow-y: auto; padding: 12px 14px; font-size: 12.5px; line-height: 1.55; }
  #chat-msgs .empty { color: var(--text-dim); font-size: 12px; line-height: 1.6; }
  #chat-msgs .msg { margin-bottom: 12px; }
  #chat-msgs .msg .who { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 3px; }
  #chat-msgs .msg.user .who { color: var(--accent); }
  #chat-msgs .msg .body { color: var(--text-primary); white-space: pre-wrap; word-break: break-word; }
  #chat-msgs .msg.assistant .body { color: #d8d8d2; }
  #chat-msgs .msg.err .body { color: var(--red-bright); }
  #chat-msgs .body pre { background: var(--bg-0); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; overflow-x: auto; font-size: 11.5px; white-space: pre; margin: 6px 0; }
  #chat-msgs .body code { background: var(--bg-0); border-radius: 3px; padding: 1px 4px; font-size: 11.5px; }
  #chat-msgs .body pre code { background: none; padding: 0; }
  #chat-panel .chat-input { display: flex; gap: 8px; padding: 10px 14px 12px; border-top: 1px solid var(--border); flex-shrink: 0; }
  #chat-panel .chat-input textarea { flex: 1; resize: none; background: var(--bg-0); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); padding: 7px 10px; font-size: 12.5px; font-family: var(--mono); }
  #chat-panel .chat-input textarea:focus { outline: none; border-color: var(--accent); }
  #chat-panel .chat-input button { background: var(--bg-2); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); padding: 0 14px; cursor: pointer; font-size: 14px; }
  #chat-panel .chat-input button:hover { border-color: var(--accent); }
  #chat-panel .chat-input button.stop { color: var(--red-bright); }

  /* ---- file modal ---- */
  #filemodal { position: fixed; inset: 0; background: rgba(0,0,0,0.66); display: none; z-index: 40; align-items: center; justify-content: center; }
  #filemodal .frame { background: var(--bg-1); border: 1px solid var(--border-bright); border-radius: 12px; width: min(920px, 92vw); height: 86vh; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 14px 40px rgba(0,0,0,0.55); }
  #filemodal .fm-header { display: flex; justify-content: space-between; align-items: center; padding: 10px 16px; border-bottom: 1px solid var(--border); font-size: 13px; }
  #filemodal .fm-header button { background: none; border: none; color: var(--text-secondary); font-size: 18px; cursor: pointer; }
  #filemodal .fm-header button:hover { color: var(--text-primary); }
  #filemodal .fm-body { overflow: auto; font-family: ui-monospace, "JetBrains Mono", monospace; font-size: 12.5px; line-height: 1.5; }
  #filemodal .fm-line { display: flex; }
  #filemodal .fm-line.hl { background: var(--accent-dim); }
  #filemodal .fm-no { width: 48px; text-align: right; padding-right: 12px; color: var(--text-dim); user-select: none; flex-shrink: 0; }
  #filemodal .fm-code { white-space: pre; padding-right: 16px; color: #c4c9d4; }
  .tk-k { color: #c792ea; }
  .tk-s { color: #8fd48f; }
  .tk-c { color: #5b6273; font-style: italic; }
  .tk-n { color: #d9a76a; }
  .tk-t { color: #7fb4d9; }
</style>
<script>if (window.self !== window.top) document.documentElement.classList.add("embedded");</script>
</head>
<body>
<div id="header">
  <a href="index.html" id="brand" title="aag home">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 5.5 6 18.5M12 5.5l6 13M6.8 15.5h10.4" stroke="#373531" stroke-width="1.3"/>
      <circle cx="12" cy="5.5" r="3" fill="#ff3b3b"/>
      <circle cx="6" cy="18.5" r="3" fill="#ffcf3b"/>
      <circle cx="18" cy="18.5" r="3" fill="#3bd8ff"/>
    </svg>
    <span><span class="word">aag</span><span class="sub">above all graphs</span></span>
  </a>
  <span id="repo-pill"></span>
  <div id="search-wrap"><input id="search" type="text" placeholder="Search nodes&hellip;"></div>
  <span class="counts"><b id="c-nodes"></b> nodes &middot; <b id="c-edges"></b> edges</span>
  <button id="sidebar-btn" title="Toggle sidebar">&#9707;</button>
  <button id="fit-btn" title="Fit view">&#10530;</button>
  <a class="hbtn" href="wiki/index.html">wiki</a>
  <a class="hbtn" href="report.html">report</a>
  <button id="chat-btn" title="AI chat">&#10024; chat</button>
  <a class="hbtn" id="star-btn" href="https://github.com/thewaifucorp/above-all-graphs" target="_blank" rel="noopener" title="Star on GitHub">&#9733; star</a>
  <a class="hbtn" id="waifu-btn" href="https://waifucorp.org" target="_blank" rel="noopener" title="Meet WaifuCorp">&#9825; waifucorp</a>
  <button id="settings-btn" title="Graph settings">&#9881;</button>
</div>

<div id="sidebar">
  <div class="tabs">
    <button id="tab-btn-explorer" class="active">Explorer</button>
    <button id="tab-btn-filters">Filters</button>
  </div>
  <div class="tab-body" id="tab-explorer"><div id="tree"></div></div>
  <div class="tab-body" id="tab-filters">
    <div class="fgroup" id="f-kinds"><h4>Node kinds</h4></div>
    <div class="fgroup" id="f-conf"><h4>Edge confidence</h4></div>
    <div class="fgroup" id="f-modules"><h4>Modules</h4></div>
  </div>
</div>

<div id="view"></div>
<div id="progress"><div>organizing graph&hellip;</div><div class="bar"><i id="progress-fill"></i></div></div>

<div id="settings-panel" class="fpanel">
  <h3>Graph settings</h3>
  <label class="check"><input type="checkbox" id="s-livesim"> Live simulation (uses CPU)</label>
  <label><span>Repulsion <b id="v-repulsion"></b></span><input type="range" id="s-repulsion" min="1" max="30" step="1"></label>
  <label><span>Gravity <b id="v-gravity"></b></span><input type="range" id="s-gravity" min="0" max="20" step="1"></label>
  <label><span>Cluster pull <b id="v-cluster"></b></span><input type="range" id="s-cluster" min="0" max="20" step="1"></label>
  <label><span>Node size <b id="v-scale"></b></span><input type="range" id="s-scale" min="0.5" max="2" step="0.1"></label>
  <label><span>Label density <b id="v-labels"></b></span><input type="range" id="s-labels" min="1" max="10" step="0.5"></label>
  <label><span>Edge opacity <b id="v-edges"></b></span><input type="range" id="s-edges" min="0.05" max="0.7" step="0.05"></label>
  <button id="s-relayout">Re-run layout</button>
  <button id="s-reset">Reset to defaults</button>
</div>

<div id="panel" class="fpanel"></div>

<div id="chat-panel" class="fpanel">
  <div class="chat-head">
    <h3>AI chat</h3>
    <button id="chat-config-btn" title="Provider settings">&#9881;</button>
  </div>
  <div id="chat-config">
    <label>Provider</label>
    <div id="cc-providers"></div>
    <label>Model <input id="cc-model" type="text" spellcheck="false"></label>
    <label id="cc-key-row">API key <input id="cc-key" type="password" placeholder="sk-&hellip;" spellcheck="false"></label>
    <label id="cc-url-row" style="display:none"><span id="cc-url-label">Base URL</span> <input id="cc-url" type="text" spellcheck="false"></label>
    <p class="cc-note">Key stays in this browser (localStorage) and goes straight to the provider &mdash; no middleman server.</p>
  </div>
  <div id="chat-msgs"><div class="empty">Ask anything about this codebase &mdash; the graph (nodes, edges, callers) plus relevant source snippets are sent as context.<br><br>Set provider + key in &#9881; first.</div></div>
  <div class="chat-input">
    <textarea id="chat-text" rows="2" placeholder="Ask about this codebase&hellip;"></textarea>
    <button id="chat-send" title="Send">&#8594;</button>
  </div>
</div>

<div id="filemodal">
  <div class="frame">
    <div class="fm-header">
      <span id="fm-title"></span>
      <button id="fm-close">&times;</button>
    </div>
    <div class="fm-body" id="fm-body"></div>
  </div>
</div>

<div id="statusbar">
  <span class="ready">&#9679; ready</span>
  <span>drag nodes &middot; scroll to zoom &middot; click node for source &middot; esc clears</span>
  <span class="right" id="status-counts"></span>
</div>

