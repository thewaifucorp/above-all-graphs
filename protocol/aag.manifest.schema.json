{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.aboveallgraphs.dev/0.2.0-proposal/aag.manifest.schema.json",
  "title": "AAG Context Manifest",
  "description": "Manifesto verificável de contexto estrutural para repositórios analisados pelo AAG Agent Protocol.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "aag_manifest",
    "repository",
    "freshness",
    "perspectives",
    "uncertainties",
    "task_recipes"
  ],
  "properties": {
    "aag_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "protocol_version", "generated_at", "generator"],
      "properties": {
        "version": { "const": "0.2.0-proposal" },
        "protocol_version": { "const": "0.2.0-proposal" },
        "generated_at": { "type": "string", "format": "date-time" },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "capabilities"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "agent": { "type": "string", "minLength": 1 },
            "implementation_url": { "type": "string", "format": "uri" },
            "capabilities": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^(static_analysis|runtime_observation|history_analysis|incremental_update|semantic_validation|task_context_selection|x-[a-z0-9][a-z0-9-]*)$"
              }
            }
          }
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root", "repository_type", "languages", "analyzed_revision"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "repository_type": {
          "type": "string",
          "enum": ["application", "library", "service", "cli", "monorepo", "mixed", "unknown"]
        },
        "languages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "path"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "path": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string" }
            }
          }
        },
        "analyzed_revision": { "type": "string", "minLength": 1 },
        "dirty_worktree": { "type": "boolean" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "analyzed_revision", "checked_at"],
      "properties": {
        "status": { "enum": ["current", "stale", "partial", "unknown"] },
        "analyzed_revision": { "type": "string", "minLength": 1 },
        "current_revision": { "type": "string", "minLength": 1 },
        "checked_at": { "type": "string", "format": "date-time" },
        "working_tree_changed": { "type": "boolean" },
        "changed_files_since_analysis": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": { "type": "string" }
      }
    },
    "perspectives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declared", "observed", "historical"],
      "properties": {
        "declared": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ownership", "purpose", "invariants", "constraints"],
          "properties": {
            "ownership": { "const": "human" },
            "purpose": { "type": "string" },
            "declared_architecture": { "type": "string" },
            "invariants": {
              "type": "array",
              "items": { "$ref": "#/$defs/declaration" }
            },
            "constraints": {
              "type": "array",
              "items": { "$ref": "#/$defs/declaration" }
            },
            "glossary": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["term", "definition"],
                "properties": {
                  "term": { "type": "string", "minLength": 1 },
                  "definition": { "type": "string", "minLength": 1 },
                  "evidence": { "$ref": "#/$defs/evidence" }
                }
              }
            }
          }
        },
        "observed": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ownership",
            "inventory",
            "entrypoints",
            "entities",
            "relationships",
            "flows",
            "side_effects",
            "architectural_findings"
          ],
          "properties": {
            "ownership": { "const": "agent" },
            "inventory": {
              "type": "object",
              "additionalProperties": false,
              "required": ["files_analyzed", "files_ignored", "entities", "relationships"],
              "properties": {
                "files_analyzed": { "type": "integer", "minimum": 0 },
                "files_ignored": { "type": "integer", "minimum": 0 },
                "entities": { "type": "integer", "minimum": 0 },
                "relationships": { "type": "integer", "minimum": 0 },
                "ignored_regions": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            },
            "entrypoints": {
              "type": "array",
              "items": { "$ref": "#/$defs/entrypoint" }
            },
            "entities": {
              "type": "array",
              "items": { "$ref": "#/$defs/entity" }
            },
            "relationships": {
              "type": "array",
              "items": { "$ref": "#/$defs/relationship" }
            },
            "flows": {
              "type": "array",
              "items": { "$ref": "#/$defs/flow" }
            },
            "side_effects": {
              "type": "array",
              "items": { "$ref": "#/$defs/sideEffect" }
            },
            "architectural_findings": {
              "type": "array",
              "items": { "$ref": "#/$defs/finding" }
            }
          }
        },
        "historical": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ownership", "analyzed", "findings"],
          "properties": {
            "ownership": { "const": "shared" },
            "analyzed": { "type": "boolean" },
            "revision_range": { "type": "string" },
            "commit_count": { "type": "integer", "minimum": 0 },
            "findings": {
              "type": "array",
              "items": { "$ref": "#/$defs/historicalFinding" }
            }
          }
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "items": { "$ref": "#/$defs/uncertainty" }
    },
    "task_recipes": {
      "type": "array",
      "items": { "$ref": "#/$defs/taskRecipe" }
    },
    "extensions": {
      "type": "object",
      "propertyNames": { "pattern": "^x-[a-z0-9][a-z0-9-]*$" },
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]*$"
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unresolved"]
    },
    "ownershipOrigin": {
      "type": "string",
      "enum": ["human", "agent", "tool", "mixed"]
    },
    "location": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["source", "revision", "runtime", "external"] }
      },
      "oneOf": [
        {
          "properties": {
            "kind": { "const": "source" },
            "file": { "type": "string", "minLength": 1 },
            "symbol": { "type": "string", "minLength": 1 },
            "line_start": { "type": "integer", "minimum": 1 },
            "line_end": { "type": "integer", "minimum": 1 },
            "section": { "type": "string", "minLength": 1 }
          },
          "required": ["kind", "file"],
          "additionalProperties": false
        },
        {
          "properties": {
            "kind": { "const": "revision" },
            "commit": { "type": "string", "minLength": 1 },
            "repository_path": { "type": "string", "minLength": 1 }
          },
          "required": ["kind", "commit"],
          "additionalProperties": false
        },
        {
          "properties": {
            "kind": { "const": "runtime" },
            "trace_id": { "type": "string", "minLength": 1 },
            "artifact": { "type": "string", "minLength": 1 }
          },
          "required": ["kind", "trace_id"],
          "additionalProperties": false
        },
        {
          "properties": {
            "kind": { "const": "external" },
            "system": { "type": "string", "minLength": 1 },
            "operation": { "type": "string", "minLength": 1 }
          },
          "required": ["kind", "system", "operation"],
          "additionalProperties": false
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "origin", "location"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ast_definition",
            "ast_import",
            "ast_call",
            "ast_inheritance",
            "ast_registration",
            "text_reference",
            "test_reference",
            "execution_trace",
            "log_observation",
            "test_execution",
            "database_trace",
            "network_trace",
            "git_commit",
            "git_blame",
            "co_change_analysis",
            "readme",
            "architecture_document",
            "inline_comment",
            "agent_instruction",
            "maintainer_assertion",
            "inferred_relationship"
          ]
        },
        "origin": { "$ref": "#/$defs/ownershipOrigin" },
        "location": { "$ref": "#/$defs/location" },
        "revision": { "type": "string", "minLength": 1 },
        "detail": { "type": "string" },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "type": "string", "minLength": 1 },
        "status": { "enum": ["declared", "accepted", "deprecated", "unknown"] },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "name", "confidence", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": {
          "type": "string",
          "pattern": "^(file|module|namespace|function|method|class|interface|type|entrypoint|command|event|handler|job|data_store|external_system|test|x-entity-[a-z0-9-]+)$"
        },
        "name": { "type": "string", "minLength": 1 },
        "package_id": { "$ref": "#/$defs/id" },
        "location": { "$ref": "#/$defs/location" },
        "summary": { "type": "string" },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source_id", "type", "target_id", "confidence", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "source_id": { "$ref": "#/$defs/id" },
        "type": {
          "type": "string",
          "pattern": "^(imports|exports|defines|contains|extends|implements|instantiates|calls|dispatches|handles|reads|writes|validates|transforms|serializes|authorizes|tests|publishes|subscribes|invalidates|schedules|retries|logs|sends|changes_with|introduced_by|frequently_modified|x-relation-[a-z0-9-]+)$"
        },
        "target_id": { "$ref": "#/$defs/id" },
        "summary": { "type": "string" },
        "conditional": { "type": "boolean" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "entity_id", "confidence", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["http", "cli", "event", "job", "message", "library_api", "ui", "other"] },
        "label": { "type": "string", "minLength": 1 },
        "entity_id": { "$ref": "#/$defs/id" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "flowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entity_id"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "entity_id": { "$ref": "#/$defs/id" },
        "via_relationship_id": { "$ref": "#/$defs/id" },
        "note": { "type": "string" },
        "next": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "async_boundary": { "type": "boolean" },
        "fan_out": { "type": "boolean" }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entrypoint_id", "steps", "confidence", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "entrypoint_id": { "$ref": "#/$defs/id" },
        "summary": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/flowStep" }
        },
        "side_effect_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "sideEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "source_entity_id", "target", "confidence", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["data_write", "event_publish", "cache_change", "external_call", "file_write", "message_send", "log", "other"] },
        "source_entity_id": { "$ref": "#/$defs/id" },
        "target": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "classification", "observed_statement", "confidence", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "classification": { "enum": ["declared_observed_conflict", "architectural_deviation", "coupling", "risk", "observation"] },
        "declared_statement_id": { "$ref": "#/$defs/id" },
        "observed_statement": { "type": "string", "minLength": 1 },
        "affected_entity_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "historicalFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "statement", "confidence", "evidence"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["co_change", "hotspot", "recent_change", "legacy_region", "introduced_relationship", "removed_relationship"] },
        "statement": { "type": "string", "minLength": 1 },
        "affected_entity_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "reason", "affected_entity_ids", "confidence", "recommended_verification", "origin"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "affected_entity_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" }
        },
        "confidence": { "const": "unresolved" },
        "recommended_verification": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "origin": { "$ref": "#/$defs/ownershipOrigin" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "taskRecipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "start_from", "expand", "must_include"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "type": "string", "minLength": 1 },
        "start_from": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "expand": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "must_include": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "max_depth": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
